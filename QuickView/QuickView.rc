// QuickView.rc - Resource file
// Application Icon

#ifndef __INTELLISENSE__
#include <windows.h>
#endif
#include "resource.h"

// Main Application Icon (ID = 1 for default)
// IDI_APPLICATION will be overridden by this
1 ICON "..\\QuickView.ico"

// Version Information - This sets the display name in Windows
 VS_VERSION_INFO VERSIONINFO
 FILEVERSION 6,10,8,0
 PRODUCTVERSION 6,10,8,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "QuickView"
            VALUE "FileDescription", "QuickView"
            VALUE "FileVersion", "6.10.8.0"
            VALUE "InternalName", "QuickView"
            VALUE "LegalCopyright", "Copyright (C) 2026"
            VALUE "OriginalFilename", "QuickView.exe"
            VALUE "ProductName", "QuickView"
            VALUE "ProductVersion", "6.10.8.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// ICC Profiles (Only existing files)
IDR_ICC_P3          ICC                     "ICC\\DisplayP3.icc"
IDR_ICC_ADOBERGB    ICC                     "ICC\\AdobeRGB.icc"
IDR_ICC_PROPHOTO    ICC                     "ICC\\ProPhoto.icc"

// ============================================================================
// Manifest
// ============================================================================
1 RT_MANIFEST "QuickView.manifest"
