     set(CMAKE_REQUIRED_FLAGS "${NEONFLAG} ${NATIVEFLAG} ${ZNOLTOFLAG}")
     check_c_source_compiles(
-        "#if defined(_M_ARM64) || defined(_M_ARM64EC)
+        "#if (defined(_M_ARM64) || defined(_M_ARM64EC)) && !defined(__clang__)
         #  include <arm64_neon.h>
